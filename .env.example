# --- Firebase (server / Admin SDK) ---
# Project ID from console.firebase.google.com → project settings.
FIREBASE_PROJECT_ID="rundnd-fd1dc"
# Default bucket — pattern is <project-id>.firebasestorage.app for new projects
# (older projects use <project-id>.appspot.com).
FIREBASE_STORAGE_BUCKET="rundnd-fd1dc.firebasestorage.app"
# Path to the service account JSON downloaded from Firebase project settings →
# Service accounts → Generate new private key. Keep this file OUTSIDE the repo.
GOOGLE_APPLICATION_CREDENTIALS="/Users/you/.firebase/aidm-service-account.json"
# Alternative: inline credentials (mutually exclusive with the JSON path).
# Used when the host can't read a file (CI, some serverless runtimes).
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# --- Firebase (client / browser SDK) ---
# All NEXT_PUBLIC_FIREBASE_* are public by design — Firebase docs are explicit
# that these are not secrets; security lives in Firestore rules + Auth.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="rundnd-fd1dc.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="rundnd-fd1dc"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="rundnd-fd1dc.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# --- Algolia (replaces tsvector for full-text recall) ---
# Algolia dashboard → API Keys. Admin key is server-only (writes); search key
# is browser-safe (read-only, scoped to specific indices).
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""

# --- LLM providers ---
# Anthropic: Opus / Sonnet / Haiku. Primary provider — backs `thinking` and
# `creative` tiers; `fast` tier uses Haiku as alternate.
ANTHROPIC_API_KEY=""
# Google: Gemini 3.1 Flash backs the `fast` tier by default.
GOOGLE_API_KEY=""
# OpenAI (used for GPT 5.4 direct AND OpenRouter via baseURL swap):
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""

# --- Observability ---
# Langfuse: LLM tracing. Per-trace prompt + cost + latency + eval scores.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://us.cloud.langfuse.com"

# PostHog: product analytics + session replay + error tracking + feature flags.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
